# NEXT.JS ENVIRONMENT CONFIGURATION
PORT=3000
LOG_LEVEL=info

# SUPABASE DEPLOYMENT (Leave empty to use in-memory Mock store)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# LOCAL OLLAMA SERVER CONFIGURATION (For Llama 3.1 Reasoning)
# In Docker containers, set this to http://host.docker.internal:11434
# Locally, default is http://localhost:11434
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
